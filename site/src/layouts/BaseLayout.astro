---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Blobsim Observatory</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,700;1,8..60,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="border-b" style="border-color: var(--border);">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" style="color: var(--foreground);" class="no-underline">
          <span class="text-lg font-semibold">Blobsim</span>
          <span class="ml-2 text-sm font-normal" style="color: var(--muted-foreground);">Observatory</span>
        </a>
      </div>
    </nav>

    <main class="mx-auto max-w-5xl px-6 py-10">
      <slot />
    </main>
  </body>
</html>
